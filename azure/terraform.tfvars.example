# Copy to terraform.tfvars and customize values.
# terraform.tfvars is gitignored and not committed.

location            = "westeurope"
resource_group_name = "cloud-automation-rg"
vm_name             = "cloud-automation-dev"
vm_size             = "Standard_D2s_v5"

# Optional tags for cost tracking/governance.
environment = "dev"
project     = "clawless"
owner       = "your-name"

# Numeric Telegram user ID for DM + owner commands (not @username).
telegram_user_id = "your-telegram-user-id"

# GitHub PAT for OpenClaw / gh. Never commit real values here (gitignored).
github_token = "your-github-pat"

vercel_token = "your-vercel-token"

azure_openai_api_key                  = "your-azure-openai-api-key"
azure_openai_endpoint                 = "your-azure-openai-endpoint"
azure_openai_realtime_deployment_name = "your-realtime-deployment-name"

openai_api_key = "your-openai-api-key"

twilio_auth_token = "your-twilio-auth-token"

realtime_public_url = "https://your-realtime-public-url"

realtime_provider = "azure"

realtime_caddy_hostname = ""

# cloudflare_tunnel_token = "eyJ..."
