#cloud-config

users:
  - name: dev
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    ssh_authorized_keys:
      - ${ssh_public_key}

package_update: true
package_upgrade: true

packages:
  - git
  - curl
  - wget
  - unzip
  - ca-certificates
  - build-essential
  - tmux
  - htop
  - xvfb
  - libnss3
  - libatk1.0-0
  - libx11-xcb1
  - libxcomposite1
  - libxdamage1
  - libxrandr2
  - libgbm1

runcmd:
  # Docker
  - curl -fsSL https://get.docker.com | sh
  - usermod -aG docker dev

  # Docker Compose v2
  - mkdir -p /usr/local/lib/docker/cli-plugins
  - curl -SL https://github.com/docker/compose/releases/download/v2.27.0/docker-compose-linux-x86_64 -o /usr/local/lib/docker/cli-plugins/docker-compose
  - chmod +x /usr/local/lib/docker/cli-plugins/docker-compose

  # Python basics
  - apt-get install -y python3 python3-pip python3-venv

  # Node.js and npm (for Playwright)
  - curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
  - apt-get install -y nodejs

  # GitHub CLI (https://github.com/cli/cli/blob/trunk/docs/install_linux.md)
  - |
    mkdir -p -m 755 /etc/apt/keyrings
    wget -qO- https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | tee /etc/apt/keyrings/githubcli-archive-keyring.gpg > /dev/null
    chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list
    apt-get update -y
    apt-get install -y gh

  # Quality-of-life
  - echo 'alias ll="ls -alh"' >> /home/dev/.bashrc
  - echo 'export DOCKER_BUILDKIT=1' >> /home/dev/.bashrc

  # OpenClaw: config dir (uid 1000 = node in container)
  - mkdir -p /home/dev/.openclaw/workspace
  - chown -R 1000:1000 /home/dev/.openclaw
  # Clone OpenClaw
  - git clone --depth 1 https://github.com/openclaw/openclaw.git /opt/openclaw
  - chown -R dev:dev /opt/openclaw
  # Generate token, .env, and full onboarded config
  - |
    TOKEN=$(openssl rand -hex 32)
    TGID="${telegram_user_id}"
    AZURE_KEY="your-azure-openai-api-key"
    AZURE_EP="your-azure-openai-endpoint"
    echo "OPENCLAW_CONFIG_DIR=/home/dev/.openclaw" > /opt/openclaw/.env
    echo "OPENCLAW_WORKSPACE_DIR=/home/dev/.openclaw/workspace" >> /opt/openclaw/.env
    echo "OPENCLAW_GATEWAY_TOKEN=$TOKEN" >> /opt/openclaw/.env
    echo "OPENCLAW_GATEWAY_PORT=18789" >> /opt/openclaw/.env
    echo "OPENCLAW_GATEWAY_BIND=lan" >> /opt/openclaw/.env
    echo "OPENCLAW_IMAGE=openclaw:local" >> /opt/openclaw/.env
    echo "GEMINI_API_KEY=your-google-api-key" >> /opt/openclaw/.env
    echo "OPENAI_API_KEY=your-openai-api-key" >> /opt/openclaw/.env
    echo "AZURE_OPENAI_API_KEY=$AZURE_KEY" >> /opt/openclaw/.env
    echo "AZURE_OPENAI_ENDPOINT=$AZURE_EP" >> /opt/openclaw/.env
    echo "AZURE_OPENAI_API_VERSION=2025-04-01-preview" >> /opt/openclaw/.env
    echo "TELEGRAM_BOT_TOKEN=your-telegram-bot-token" >> /opt/openclaw/.env
    echo "NOTION_API_KEY=your-notion-api-key" >> /opt/openclaw/.env
    echo "VERCEL_TOKEN=your-vercel-token" >> /opt/openclaw/.env
    echo "VAPI_API_KEY=your-vapi-api-key" >> /opt/openclaw/.env
    echo "GITHUB_TOKEN=${github_token}" >> /opt/openclaw/.env
    echo "APIFY_TOKEN=your-apify-token" >> /opt/openclaw/.env
    echo "$TOKEN" > /home/dev/.openclaw-gateway-token
    chown dev:dev /home/dev/.openclaw-gateway-token
    chmod 600 /home/dev/.openclaw-gateway-token
    chown dev:dev /opt/openclaw/.env
    chmod 600 /opt/openclaw/.env
    cat > /opt/openclaw/docker-compose.override.yml << 'OVEOF'
    services:
      openclaw-gateway:
        environment:
          GEMINI_API_KEY: $${GEMINI_API_KEY}
          OPENAI_API_KEY: $${OPENAI_API_KEY}
          AZURE_OPENAI_API_KEY: $${AZURE_OPENAI_API_KEY}
          AZURE_OPENAI_ENDPOINT: $${AZURE_OPENAI_ENDPOINT}
          AZURE_OPENAI_API_VERSION: $${AZURE_OPENAI_API_VERSION}
          TELEGRAM_BOT_TOKEN: $${TELEGRAM_BOT_TOKEN}
          GITHUB_TOKEN: $${GITHUB_TOKEN}
      openclaw-cli:
        environment:
          GEMINI_API_KEY: $${GEMINI_API_KEY}
          OPENAI_API_KEY: $${OPENAI_API_KEY}
          AZURE_OPENAI_API_KEY: $${AZURE_OPENAI_API_KEY}
          AZURE_OPENAI_ENDPOINT: $${AZURE_OPENAI_ENDPOINT}
          AZURE_OPENAI_API_VERSION: $${AZURE_OPENAI_API_VERSION}
          TELEGRAM_BOT_TOKEN: $${TELEGRAM_BOT_TOKEN}
          GITHUB_TOKEN: $${GITHUB_TOKEN}
    OVEOF
    chown dev:dev /opt/openclaw/docker-compose.override.yml
    cat > /home/dev/.openclaw/.env << 'ENVEOF'
    GEMINI_API_KEY=your-google-api-key
    OPENAI_API_KEY=your-openai-api-key
    AZURE_OPENAI_API_KEY=your-azure-openai-api-key
    AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint
    AZURE_OPENAI_API_VERSION=2025-04-01-preview
    TELEGRAM_BOT_TOKEN=your-telegram-bot-token
    NOTION_API_KEY=your-notion-api-key
    VERCEL_TOKEN=your-vercel-token
    VAPI_API_KEY=your-vapi-api-key
    GITHUB_TOKEN=${github_token}
    APIFY_TOKEN=your-apify-token
    ENVEOF
    chown 1000:1000 /home/dev/.openclaw/.env
    chmod 600 /home/dev/.openclaw/.env
    cat > /home/dev/.openclaw/openclaw.json << OCEOF
    {
      "messages": { "ackReactionScope": "group-mentions" },
      "models": {
        "providers": {
          "azure-openai-responses": {
            "baseUrl": "$AZURE_EP",
            "apiKey": "$AZURE_KEY",
            "api": "openai-completions",
            "authHeader": false,
            "headers": { "api-key": "$AZURE_KEY" },
            "models": [
              {
                "id": "gpt-5.5",
                "name": "GPT-5.5 (Azure)",
                "reasoning": false,
                "input": ["text", "image"],
                "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
                "contextWindow": 272000,
                "maxTokens": 128000,
                "compat": { "supportsStore": false }
              }
            ]
          }
        }
      },
      "agents": {
        "defaults": {
          "maxConcurrent": 4,
          "subagents": { "maxConcurrent": 8 },
          "compaction": { "mode": "safeguard", "reserveTokensFloor": 20000 },
          "workspace": "~/.openclaw/workspace",
          "model": {
            "primary": "azure-openai-responses/gpt-5.5"
          },
          "models": {
            "azure-openai-responses/gpt-5.5": {}
          }
        }
      },
      "gateway": {
        "mode": "local",
        "auth": { "mode": "token", "token": "$TOKEN" },
        "port": 18789,
        "bind": "lan",
        "controlUi": {
          "allowedOrigins": [
            "http://localhost:18789",
            "http://127.0.0.1:18789",
            "http://your-vm-public-ip:18789"
          ]
        },
        "tailscale": { "mode": "off", "resetOnExit": false },
        "nodes": {
          "denyCommands": [
            "camera.snap", "camera.clip", "screen.record",
            "calendar.add", "contacts.add", "reminders.add"
          ]
        }
      },
      "plugins": {
        "entries": {
          "telegram": { "enabled": true },
          "google": { "enabled": true }
        }
      },
      "channels": {
        "telegram": {
          "enabled": true,
          "botToken": "\$${TELEGRAM_BOT_TOKEN}",
          "dmPolicy": "allowlist",
          "allowFrom": ["$${TGID}"],
          "groupAllowFrom": ["$${TGID}"]
        }
      },
      "commands": { "ownerAllowFrom": ["telegram:$${TGID}"] },
      "skills": {
        "install": { "nodeManager": "npm" },
        "entries": {
          "goplaces": { "apiKey": "\$${GEMINI_API_KEY}" },
          "local-places": { "apiKey": "\$${GEMINI_API_KEY}" },
          "nano-banana-pro": { "apiKey": "\$${GEMINI_API_KEY}" },
          "notion": { "apiKey": "\$${NOTION_API_KEY}" }
        }
      },
      "hooks": {
        "internal": {
          "enabled": true,
          "entries": {
            "boot-md": { "enabled": true },
            "command-logger": { "enabled": true },
            "session-memory": { "enabled": true }
          }
        }
      },
      "wizard": {
        "lastRunAt": "2026-02-09T23:04:54.832Z",
        "lastRunVersion": "2026.2.9",
        "lastRunCommand": "onboard",
        "lastRunMode": "local"
      },
      "meta": {
        "lastTouchedVersion": "2026.2.9",
        "lastTouchedAt": "2026-02-09T23:04:54.864Z"
      }
    }
    OCEOF
    chown 1000:1000 /home/dev/.openclaw/openclaw.json
    chmod 600 /home/dev/.openclaw/openclaw.json
  # Build and start OpenClaw gateway (first boot may take 15–20 min)
  - cd /opt/openclaw && docker build -t openclaw:local -f Dockerfile .
  - cd /opt/openclaw && docker compose up -d openclaw-gateway
  # After gateway is running, seed workspace persona files (overwrite bootstrap).
  - |
    for i in $(seq 1 72); do
      cd /opt/openclaw && docker compose exec -T openclaw-gateway true 2>/dev/null && break
      sleep 5
    done
    sleep 15
    install -d -o 1000 -g 1000 -m 0755 /home/dev/.openclaw/workspace
    printf '%s' "${workspace_identity_b64}" | base64 -d > /home/dev/.openclaw/workspace/IDENTITY.md
    printf '%s' "${workspace_user_b64}" | base64 -d > /home/dev/.openclaw/workspace/USER.md
    printf '%s' "${workspace_soul_b64}" | base64 -d > /home/dev/.openclaw/workspace/SOUL.md
    chown 1000:1000 /home/dev/.openclaw/workspace/IDENTITY.md /home/dev/.openclaw/workspace/USER.md /home/dev/.openclaw/workspace/SOUL.md
