# Copy to terraform.tfvars and set your GCP project ID.
# terraform.tfvars is gitignored and not committed.

project_id = "your-gcp-project-id"

# Numeric Telegram user ID (Not @username). Same value OpenClaw uses for
# allowFrom, groupAllowFrom, and commands.ownerAllowFrom.
telegram_user_id = "your-telegram-user-id"

# GitHub PAT (classic ghp_… or fine-grained). Same value as cloud-init GITHUB_*.
github_token = "your-github-pat"
